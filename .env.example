# ============================================================
# Server
# ============================================================

# Port aplikasi berjalan (opsional di Vercel/Netlify, otomatis diatur platform)
PORT=8081

# ============================================================
# Authentication
# ============================================================

# API Key untuk mengamankan endpoint REST gateway ini
WA_GATEWAY_API_KEY=dev-api-key

# ============================================================
# Webhook / Callback
# ============================================================

# URL endpoint Laravel yang akan menerima callback dari gateway
# (session_connected, session_disconnected, message_received, message_delivered)
# alamat ke api laravel 
# LARAVEL_WEBHOOK_URL=http://localhost:8000/api/v1/wa/delivery-callback
LARAVEL_WEBHOOK_URL=http://localhost:8000/api/v1/wa/delivery-callback

# Secret key untuk memverifikasi callback dari gateway di sisi Laravel
# Dikirim via header: X-Callback-Secret
WA_CALLBACK_SECRET=dev-callback-secret